# ─────────────────────────────────────────────────────────────────
# UniCloud web/ (React + Vite) — example env
# ─────────────────────────────────────────────────────────────────
# Copy to `.env.local` (gitignored) and fill in real values.

# API endpoints
VITE_API_BASE_URL=
VITE_ADMIN_API_URL=
VITE_TENANT_API_URL=

# ─── Sentry (frontend error tracking) ───────────────────────────
# Leave empty to disable Sentry entirely (dev default).
VITE_SENTRY_DSN=

# Sampling — 0.0 disables tracing, 1.0 = every pageload.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Release — set by CI to the git SHA so Sentry can map errors
# to the exact build.
# VITE_SENTRY_RELEASE=

# ─── Payments ────────────────────────────────────────────────────
# Public keys only — never put secret keys in frontend env.
VITE_PAYSTACK_PUBLIC_KEY=

# ─── ConveyThis (translation widget) ─────────────────────────────
# Public translation key — the script is a no-op when unset, so
# dev environments can leave it blank.
# See index.html for the initializer + SRI guard.
VITE_CONVEYTHIS_KEY=

# ─── Firebase (optional) ─────────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
