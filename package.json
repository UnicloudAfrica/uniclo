{
  "name": "unicloud",
  "homepage": "http://unicloudafrica.com/",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@dr.pogodin/react-helmet": "^3.1.0",
    "@paystack/inline-js": "^2.22.8",
    "@sentry/react": "^8.55.1",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/user-event": "^14.6.1",
    "@tinymce/tinymce-react": "^6.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.6",
    "countries-list": "^3.2.2",
    "country-state-city": "^3.2.1",
    "dompurify": "^3.3.1",
    "firebase": "^10.14.0",
    "framer-motion": "^12.34.3",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.7",
    "laravel-echo": "^2.3.0",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.576.0",
    "mermaid": "^11.13.0",
    "papaparse": "^5.5.3",
    "pusher-js": "^8.4.0",
    "react": "^19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-dropzone": "^14.3.8",
    "react-i18next": "^17.0.4",
    "react-intersection-observer": "^10.0.3",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^10.1.0",
    "react-paystack": "^6.0.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "topojson-client": "^3.1.0",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=65536' vite",
    "start": "NODE_OPTIONS='--max-http-header-size=65536' vite",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "build:client": "NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "build:ssr": "NODE_OPTIONS='--max-old-space-size=4096' vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "prerender": "node scripts/prerender.mjs",
    "build:static": "npm run build:client && npm run build:ssr && npm run prerender",
    "preview": "vite preview",
    "typecheck": "npm run typecheck:full",
    "typecheck:full": "node scripts/typecheck-runner.mjs --label full",
    "typecheck:admin": "node scripts/typecheck-runner.mjs --label admin --project tsconfig.typecheck.admin.json",
    "typecheck:dashboards": "node scripts/typecheck-runner.mjs --label dashboards --project tsconfig.typecheck.dashboard.json",
    "typecheck:core": "node scripts/typecheck-runner.mjs --label core --project tsconfig.typecheck.core.json",
    "typecheck:all": "npm run typecheck:admin && npm run typecheck:dashboards && npm run typecheck:core",
    "typecheck:all:parallel": "node scripts/typecheck-parallel.mjs",
    "typecheck:rank": "node scripts/ts-error-rank.mjs",
    "typecheck:rank:full": "node scripts/ts-error-rank.mjs .cache/ts-errors/full.log",
    "typecheck:rank:admin": "node scripts/ts-error-rank.mjs .cache/ts-errors/admin.log",
    "typecheck:rank:dashboards": "node scripts/ts-error-rank.mjs .cache/ts-errors/dashboards.log",
    "typecheck:rank:core": "node scripts/ts-error-rank.mjs .cache/ts-errors/core.log",
    "typecheck:clean": "rm -rf .cache/ts-errors .cache/tsc*.tsbuildinfo",
    "lint": "eslint --cache --cache-location .cache/eslint --ext .ts,.tsx src",
    "lint:fix": "eslint --cache --cache-location .cache/eslint --fix --ext .ts,.tsx src",
    "lint:full": "eslint --ext .ts,.tsx src",
    "lint:clean": "rm -rf .cache/eslint",
    "theme:audit": "node scripts/theme-audit.mjs",
    "theme:audit:strict": "node scripts/theme-audit.mjs --strict",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,md}",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "src/**/*.{css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/register": "^7.28.6",
    "@chromatic-com/storybook": "^5.1.2",
    "@faker-js/faker": "^10.3.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "faker": "^6.6.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "msw": "^2.12.10",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
